+  if (!hermesUser) {
+    ctx.status = 404
+    ctx.body = { error: 'User not found' }
+    return
+  }
+
+  if (ctx.state.user?.id === hermesUser.id) {
+    ctx.status = 400
+    ctx.body = { error: 'You cannot delete your own account' }
