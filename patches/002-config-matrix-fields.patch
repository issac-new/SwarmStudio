+/**
+ * Base URL of the Hermes agent dashboard that serves the kanban plugin page.
+ * The /hermes/kanban view embeds `${dashboardUrl}/kanban` in an iframe; the
+ * dashboard injects its own session token into the served HTML on loopback, so
+ * the embedded page authenticates itself without any token handling here.
+ * Default assumes the dashboard is running on its default loopback port.
+ */
+export function getDashboardUrl(env: Record<string, string | undefined> = process.env): string {
+  const url = env.HERMES_DASHBOARD_URL?.trim()
+  if (url) return url.replace(/\/+$/, '')
+  const host = env.HERMES_DASHBOARD_HOST?.trim() || '127.0.0.1'
+  const port = parseInt(env.HERMES_DASHBOARD_PORT || '9119', 10)
+  return `http://${host}:${port}`
+}
