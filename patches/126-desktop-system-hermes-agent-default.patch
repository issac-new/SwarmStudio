+function resolveExecutable(command: string): string | undefined {
+  const trimmed = command.trim()
+  if (!trimmed) return undefined
+  if (trimmed.includes('/') || trimmed.includes('\\')) {
+    return existsSync(trimmed) ? resolve(trimmed) : undefined
+  }
+  try {
+    const lookup = process.platform === 'win32'
+      ? execFileSync('where.exe', [trimmed], { encoding: 'utf-8', windowsHide: true })
+      : execFileSync('which', [trimmed], { encoding: 'utf-8' })
+    return lookup.split(/\r?\n/).map(line => line.trim()).find(Boolean)
+  } catch {
+    return undefined
+  }
+}
+
+function preferredSystemHermesCommand(): string {
+  return process.env.HERMES_SYSTEM_BIN?.trim() || process.env.HERMES_BIN?.trim() || 'hermes'
+}
+
+export function systemHermesBin(): string | undefined {
+  return resolveExecutable(preferredSystemHermesCommand())
+}
+
+export function usingSystemHermesAgent(): boolean {
+  if (process.env.HERMES_DESKTOP_FORCE_BUNDLED_RUNTIME?.trim()) return false
+  return !!systemHermesBin()
+}
+
+export function systemHermesPython(): string | undefined {
+  const hermes = systemHermesBin()
+  if (!hermes) return undefined
+  try {
+    const first = readFileSync(hermes, 'utf-8').split(/\r?\n/, 1)[0]
+    const match = first.match(/^#!\s*(.+)$/)
+    return match?.[1]?.trim().split(/\s+/)[0]
+  } catch {
+    return undefined
+  }
+}
