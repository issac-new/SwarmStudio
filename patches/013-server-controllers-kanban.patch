+// ─── Orchestration ──────────────────────────────────────────────
+
+import { readConfigYaml, writeConfigYaml } from '../../services/config-helpers'
+
+export async function getOrchestration(ctx: Context) {
+  try {
+    const config = await readConfigYaml()
+    const kanban = config.kanban || {}
+    const explicitOrch = kanban.orchestrator_profile || null
+    const explicitDefault = kanban.default_assignee || null
+    const autoDecompose = kanban.auto_decompose !== false // default true
+    const autoPromoteChildren = kanban.auto_promote_children === true // default false
+
+    // Resolve fallbacks
+    const profiles = listProfileNamesFromDisk()
+    const activeProfile = config.profile?.default || 'default'
+    const resolvedOrch = explicitOrch || activeProfile
+    const resolvedDefault = explicitDefault || activeProfile
+
+    ctx.body = {
+      orchestrator_profile: explicitOrch,
+      default_assignee: explicitDefault,
+      auto_decompose: autoDecompose,
+      auto_promote_children: autoPromoteChildren,
+      resolved_orchestrator_profile: resolvedOrch,
+      resolved_default_assignee: resolvedDefault,
+      active_profile: activeProfile,
+      profiles,
+    }
+  } catch (err: any) {
+    ctx.status = 500
+    ctx.body = { error: err.message }
+  }
+}
+
+export async function setOrchestration(ctx: Context) {
+  const bodyResult = requestBody(ctx)
+  if (rejectBadRequest(ctx, bodyResult.error)) return
+  const body = bodyResult.body
+
+  try {
+    const config = await readConfigYaml()
+    const kanban = config.kanban || {}
+
+    // Validate profile names if provided
+    const profiles = new Set(listProfileNamesFromDisk())
+    if (hasOwn(body, 'orchestrator_profile')) {
+      const orch = body.orchestrator_profile
+      if (orch !== null && orch !== undefined && !profiles.has(orch as string)) {
+        ctx.status = 400
+        ctx.body = { error: `Profile "${orch}" does not exist` }
+        return
+      }
+      if (orch === null || orch === undefined) {
+        delete kanban.orchestrator_profile
+      } else {
+        kanban.orchestrator_profile = orch as string
+      }
+    }
+    if (hasOwn(body, 'default_assignee')) {
+      const def = body.default_assignee
+      if (def !== null && def !== undefined && !profiles.has(def as string)) {
+        ctx.status = 400
+        ctx.body = { error: `Profile "${def}" does not exist` }
+        return
+      }
+      if (def === null || def === undefined) {
+        delete kanban.default_assignee
+      } else {
+        kanban.default_assignee = def as string
+      }
+    }
+    if (hasOwn(body, 'auto_decompose')) {
+      kanban.auto_decompose = !!body.auto_decompose
+    }
+    if (hasOwn(body, 'auto_promote_children')) {
+      kanban.auto_promote_children = !!body.auto_promote_children
+    }
+
+    config.kanban = kanban
+    await writeConfigYaml(config)
+
+    // Return updated settings
+    await getOrchestration(ctx)
+  } catch (err: any) {
+    ctx.status = 500
+    ctx.body = { error: err.message }
+  }
+}
