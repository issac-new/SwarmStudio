+        if (requestedSource === 'human' && authenticatedUser) {
+            try {
+                const visibleRooms = authenticatedUser.role === 'super_admin'
+                    ? this.storage.getAllRooms()
+                    : this.storage.getRoomsForProfiles(authenticatedUser.profiles || [])
+                const sync: { roomId: string; unreadCount: number; lastMessage: { content: string; senderName: string; ts: number } | null }[] = []
+                for (const r of visibleRooms) {
+                    let room = this.rooms.get(r.id)
+                    if (!room) {
+                        room = new ChatRoom(r.id, r.name)
+                        this.rooms.set(r.id, room)
+                    }
+                    room.addOrUpdateMember(socket.id, userId, userName, description, 'human', '')
+                    if (typeof authUserId === 'number') {
+                        this.storage.addRoomMember(r.id, userId, userName, description, '', authUserId)
+                    }
+                    socket.join(r.id)
+                    const last = this.storage.getLastMessage(r.id)
+                    sync.push({
+                        roomId: r.id,
+                        unreadCount: 0,
+                        lastMessage: last ? { content: last.content ?? '', senderName: last.senderName ?? '', ts: typeof last.timestamp === 'number' ? last.timestamp : Date.now() } : null,
+                    })
+                }
+                socket.emit('unread_sync', sync)
+            } catch (err) {
+                logger.info(`[GroupChat] auto-join failed for ${userName}: ${(err as Error).message}`)
+            }
+        }
+        // HERMES_CUSTOM[GroupChatAutoJoin] END
+
         socket.on('join', (data: { roomId?: string; name?: string }, ack?: (response?: unknown) => void) => this.handleJoin(socket, data, ack))
