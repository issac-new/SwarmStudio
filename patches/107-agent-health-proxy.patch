+  // Proxy /agent-health/* → hermes-agent health endpoint (for CockpitTopBar)
+  const agentHealthTarget = process.env.HERMES_AGENT_HEALTH_URL || 'http://127.0.0.1:8650'
+  app.use(async (ctx, next) => {
+    if (ctx.path.startsWith('/agent-health/')) {
+      // HERMES_CUSTOM[SecAgentHealthAuth] BEGIN: 要求已认证，防未授权访问 agent 内部端点
+      if (!ctx.state.user) {
+        ctx.status = 401
+        ctx.body = { error: 'Unauthorized' }
+        return
+      }
+      // HERMES_CUSTOM[SecAgentHealthAuth] END
+      // HERMES_CUSTOM[SecAgentHealthPath] BEGIN: 限制转发路径白名单，防路径注入探测 agent 其他路由
+      const sub = ctx.path.slice('/agent-health'.length)
+      const allowed = sub === '/' || sub === '/refs' || sub.startsWith('/refs/')
+      if (!allowed) {
+        ctx.status = 404
+        ctx.body = { error: 'Not found' }
+        return
+      }
+      const targetPath = `/health${sub}`
+      // HERMES_CUSTOM[SecAgentHealthPath] END
+      const qs = ctx.querystring ? `?${ctx.querystring}` : ''
+      try {
+        const res = await fetch(`${agentHealthTarget}${targetPath}${qs}`)
+        ctx.status = res.status
+        const contentType = res.headers.get('content-type') || 'application/json'
+        ctx.type = contentType
+        ctx.body = await res.text()
+      } catch {
+        ctx.status = 502
+        ctx.body = JSON.stringify({ error: 'Agent health endpoint unreachable' })
+      }
+      return
+    }
+    await next()
+  })
+
