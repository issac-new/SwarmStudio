+  // overlay[agent-health-proxy]: Proxy /agent-health/* → hermes-agent api_server
+  // health endpoint (for CockpitTopBar). Default port 8642 is the gateway
+  // api_server default; 8650 is the dev preview backend and is usually empty
+  // in production desktop.
+  const agentHealthTarget = process.env.HERMES_AGENT_HEALTH_URL || 'http://127.0.0.1:8642'
+  app.use(async (ctx, next) => {
+    if (ctx.path.startsWith('/agent-health/')) {
+      // HERMES_CUSTOM[SecAgentHealthPath] BEGIN: limit forwarded paths to a
+      // whitelist so callers can't probe arbitrary agent routes.
+      const sub = ctx.path.slice('/agent-health'.length)
+      const allowed = sub === '/' || sub === '/detailed' || sub === '/refs' || sub.startsWith('/refs/')
+      if (!allowed) {
+        ctx.status = 404
+        ctx.body = { error: 'Not found' }
+        return
+      }
+      const targetPath = `/health${sub}`
+      // HERMES_CUSTOM[SecAgentHealthPath] END
+      const qs = ctx.querystring ? `?${ctx.querystring}` : ''
+      // HERMES_CUSTOM[AgentHealthKey] BEGIN: gateway /health/detailed needs
+      // API_SERVER_KEY auth. Read it from ~/.hermes/.env (same file the
+      // gateway reads at startup) and inject as a Bearer header.
+      const healthHeaders: Record<string, string> = {}
+      let apiKey = process.env.API_SERVER_KEY || ''
+      if (!apiKey) {
+        try {
+          const fs = require('fs')
+          const envPath = require('path').join(require('os').homedir(), '.hermes', '.env')
+          const m = fs.readFileSync(envPath, 'utf8').match(/^API_SERVER_KEY=(.+)$/m)
+          if (m) apiKey = m[1].trim()
+        } catch { /* .env missing or unreadable, ignore */ }
+      }
+      if (apiKey) healthHeaders['Authorization'] = `Bearer ${apiKey}`
+      // HERMES_CUSTOM[AgentHealthKey] END
+      // overlay[agent-health-logging]: log every proxy attempt + outcome so
+      // Windows users can ship us the log when /agent-health/* returns 502.
+      const probeUrl = `${agentHealthTarget}${targetPath}${qs}`
+      const hadKey = !!apiKey
+      console.log(`[agent-health] proxy ${ctx.method} ${ctx.path} -> ${probeUrl} (authKey=${hadKey ? 'yes' : 'no'})`)
+      try {
+        const res = await fetch(probeUrl, { headers: healthHeaders })
+        ctx.status = res.status
+        const contentType = res.headers.get('content-type') || 'application/json'
+        ctx.type = contentType
+        ctx.body = await res.text()
+        console.log(`[agent-health] <- ${res.status} ${ctx.path} (contentType=${contentType})`)
+      } catch (err) {
+        const msg = err instanceof Error ? `${err.name}: ${err.message}` : String(err)
+        console.error(`[agent-health] proxy FAILED ${ctx.path} -> ${probeUrl}: ${msg}`)
+        ctx.status = 502
+        ctx.body = JSON.stringify({ error: 'Agent health endpoint unreachable', detail: msg })
+      }
+      return
+    }
+    await next()
+  })
+
